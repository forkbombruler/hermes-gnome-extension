<?xml version="1.0" encoding="utf-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.hermes-monitor" path="/org/gnome/shell/extensions/hermes-monitor/">
    <key name="refresh-interval" type="i">
      <default>30</default>
      <summary>Refresh interval</summary>
      <description>How often (in seconds) to check for job updates (5–600)</description>
      <range min="5" max="600"/>
    </key>
    <key name="position-in-panel" type="i">
      <default>2</default>
      <summary>Position in panel</summary>
      <description>Position of the indicator (0=right, 1=center, 2=left)</description>
    </key>
    <key name="hermes-home" type="s">
      <default>'~/.hermes'</default>
      <summary>Hermes home directory</summary>
      <description>Path to Hermes configuration directory</description>
    </key>
  </schema>
</schemalist>